#!/usr/bin/env python3

#
# Copyright (C) 2026 tebbi
# SPDX-License-Identifier: GPL-3.0-or-later
#

#
# Translate the cluster smarthost (mail relay) settings into the SMTP_*
# environment variables understood by Huginn, and write them to
# state/smarthost.env which is loaded by the huginn-app container.
#
# Priority:
#   1. the manual SMTP relay configured in this module (SMTP_MANUAL_*), so an
#      administrator can always override the cluster default from the GUI
#   2. the cluster smarthost, when one is configured and enabled
#   3. nothing (Huginn keeps its built-in defaults / cannot send mail)
#
# SMTP_OPENSSL_VERIFY_MODE is derived from SMTP_MANUAL_SSL_VERIFY and applies to
# both relays: the internal cluster smarthost presents a certificate that is not
# valid for its WireGuard address, so certificate verification has to be turned
# off there, while a public manual relay normally wants it on.
#

import sys
import os
import agent

# Connect the local Redis replica so the service still starts when the leader
# node is unreachable.
rdb = agent.redis_connect(use_replica=True)
smtp = agent.get_smarthost_settings(rdb)

# Derive a HELO/from domain from the configured public host name.
host = os.environ.get("TRAEFIK_HOST", "")
domain = host.split(".", 1)[1] if "." in host else (host or "localhost")
default_from = f"huginn@{domain}"

envfile = "smarthost.env"

# Verify the SMTP server's TLS certificate? Defaults to verifying; the value is
# seeded by create-module (off when a cluster smarthost exists) and can be
# changed from the module Settings page.
ssl_verify = os.environ.get("SMTP_MANUAL_SSL_VERIFY", "true") == "true"


def write_settings(efp, *, server, port, user, password, starttls, from_address):
    authentication = "plain" if user else ""
    print(f"SMTP_SERVER={server}", file=efp)
    print(f"SMTP_PORT={port}", file=efp)
    print(f"SMTP_DOMAIN={domain}", file=efp)
    print(f"SMTP_USER_NAME={user}", file=efp)
    print(f"SMTP_PASSWORD={password}", file=efp)
    print(f"SMTP_AUTHENTICATION={authentication}", file=efp)
    print(f"SMTP_ENABLE_STARTTLS_AUTO={'true' if starttls else 'false'}", file=efp)
    print(f"EMAIL_FROM_ADDRESS={from_address or default_from}", file=efp)
    # Empty value = Ruby default (verify); "none" disables certificate checks.
    print(f"SMTP_OPENSSL_VERIFY_MODE={'' if ssl_verify else 'none'}", file=efp)


# Use a .tmp suffix so the target file is only replaced once fully written.
with open(envfile + ".tmp", "w") as efp:
    manual_host = os.environ.get("SMTP_MANUAL_HOST", "").strip()

    if manual_host:
        # 1) manual relay configured in this module (takes priority so the GUI
        #    field always wins over the cluster default)
        write_settings(
            efp,
            server=manual_host,
            port=os.environ.get("SMTP_MANUAL_PORT", "587"),
            user=os.environ.get("SMTP_MANUAL_USERNAME", ""),
            password=os.environ.get("SMTP_MANUAL_PASSWORD", ""),
            starttls=os.environ.get("SMTP_MANUAL_STARTTLS", "true") == "true",
            from_address=os.environ.get("SMTP_MANUAL_FROM", "") or default_from,
        )
    elif smtp.get("enabled"):
        # 2) cluster smarthost as fallback
        encrypt = (smtp.get("encrypt_smtp") or "none").lower()
        write_settings(
            efp,
            server=smtp["host"],
            port=smtp["port"],
            user=smtp.get("username", ""),
            password=smtp.get("password", ""),
            starttls=encrypt in ("starttls", "auto"),
            from_address=default_from,
        )
    else:
        # 3) Keep the file present but empty when no relay is configured.
        print("# smarthost not configured", file=efp)

# Commit the change atomically.
os.replace(envfile + ".tmp", envfile)
