# List the agents loaded by Huginn: the read-only agents shipped with the
# module (bundled) and the ones uploaded by the administrator (custom).

import os
import sys
import json

home = os.path.expanduser("~")
bundled_dir = os.path.join(home, ".config", "huginn-init", "bundled-agents")
custom_dir = os.path.join(home, ".config", "state", "custom_agents")


def collect(directory, bundled):
    found = []
    if os.path.isdir(directory):
        for filename in sorted(os.listdir(directory)):
            if not filename.endswith(".rb"):
                continue
            full = os.path.join(directory, filename)
            try:
                found.append(
                    {"filename": filename, "size": os.path.getsize(full), "bundled": bundled}
                )
            except OSError:
                continue
    return found


agents = collect(bundled_dir, True) + collect(custom_dir, False)

json.dump({"agents": agents}, fp=sys.stdout)
