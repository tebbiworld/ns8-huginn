# Save an uploaded custom agent into the custom_agents directory that is
# bind-mounted into the Huginn application container, run a Ruby syntax check
# inside the running container, and reload Huginn so the agent is registered.

import os
import re
import sys
import json
import subprocess

import agent

data = json.load(sys.stdin)
filename = data["filename"]
content = data["content"]

# Defend in depth against path traversal (the schema already restricts this).
if not re.fullmatch(r"[A-Za-z0-9_][A-Za-z0-9_-]*\.rb", filename):
    agent.set_status("validation-failed")
    json.dump(
        [{"field": "filename", "parameter": "filename", "value": filename, "error": "invalid_file_name"}],
        fp=sys.stdout,
    )
    sys.exit(2)

state_dir = os.path.join(os.path.expanduser("~"), ".config", "state", "custom_agents")
os.makedirs(state_dir, exist_ok=True)
path = os.path.join(state_dir, filename)

# Write atomically so a partially written file is never picked up.
tmp = path + ".tmp"
with open(tmp, "w") as fp:
    fp.write(content)
os.chmod(tmp, 0o644)
os.replace(tmp, path)

# Syntax-check inside the running container (it ships the matching Ruby).
container_running = subprocess.run(
    ["podman", "container", "exists", "huginn-app"]
).returncode == 0

if container_running:
    check = subprocess.run(
        ["podman", "exec", "huginn-app", "ruby", "-c", "/app/custom_agents/" + filename],
        capture_output=True,
        text=True,
    )
    if check.returncode != 0:
        # Reject the upload and remove the broken file.
        os.remove(path)
        agent.set_status("validation-failed")
        json.dump(
            [{
                "field": "content",
                "parameter": "content",
                "value": (check.stderr or check.stdout).strip()[:500],
                "error": "ruby_syntax_error",
            }],
            fp=sys.stdout,
        )
        sys.exit(2)

# Reload Huginn so the new agent class is loaded (custom agents are required
# at boot). --no-block keeps the action responsive; the restart finishes in
# the background.
subprocess.run(
    ["systemctl", "--user", "restart", "--no-block", "huginn-app.service"],
    check=False,
)

json.dump({"filename": filename}, fp=sys.stdout)
