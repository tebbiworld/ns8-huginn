import os
import sys
import json
import agent

config = {}

config["host"] = os.getenv("TRAEFIK_HOST", "")
config["http2https"] = os.getenv("TRAEFIK_HTTP2HTTPS") == "True"
config["timezone"] = os.getenv("TZ", "UTC")

route = agent.get_route(os.environ["MODULE_ID"])
config["lets_encrypt"] = route.get("lets_encrypt", False)

# Optional manual SMTP relay (only used when no cluster smarthost exists).
config["smtp_host"] = os.getenv("SMTP_MANUAL_HOST", "")
config["smtp_port"] = int(os.getenv("SMTP_MANUAL_PORT", "587") or 587)
config["smtp_username"] = os.getenv("SMTP_MANUAL_USERNAME", "")
config["smtp_password"] = os.getenv("SMTP_MANUAL_PASSWORD", "")
config["smtp_starttls"] = os.getenv("SMTP_MANUAL_STARTTLS", "true") == "true"
config["smtp_ssl_verify"] = os.getenv("SMTP_MANUAL_SSL_VERIFY", "true") == "true"
config["smtp_from"] = os.getenv("SMTP_MANUAL_FROM", "")

# Initial admin credentials seeded on first start (the password is only valid
# until the administrator changes it inside Huginn).
config["admin_username"] = os.getenv("SEED_USERNAME", "admin")
config["admin_password"] = os.getenv("SEED_PASSWORD", "")

json.dump(config, fp=sys.stdout)
