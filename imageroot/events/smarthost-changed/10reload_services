set -e

# Refresh the SMTP env file and restart the app container so Huginn picks up
# the new mail relay settings. Do nothing if the module is not running yet.
if systemctl --user is-enabled --quiet huginn.service; then
    runagent discover-smarthost || true
    systemctl --user restart huginn-app.service
fi
